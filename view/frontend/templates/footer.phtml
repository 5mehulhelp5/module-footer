declare(strict_types=1);

use Magento\Framework\Escaper;
use Magento\Framework\View\Element\Template;
use Panth\Footer\ViewModel\FooterData;

/** @var Escaper $escaper */
/** @var Template $block */
/** @var FooterData $footerViewModel */
$footerViewModel = $block->getData('footer_view_model');
if (!$footerViewModel || !$footerViewModel->isEnabled()) {
    return;
}
$layout = $footerViewModel->getLayout();
$gridClasses = $footerViewModel->getGridClasses();
?>

<!-- Newsletter -->
<?php if ($footerViewModel->isNewsletterEnabled()): ?>
    <?= $block->getChildHtml('panth.footer.newsletter') ?>
<?php endif; ?>

<!-- Footer -->
<footer class="panth-footer">
    <div class="max-w-7xl mx-auto px-6 py-16">

        <!-- Footer Columns -->
        <div class="grid <?= $escaper->escapeHtmlAttr($gridClasses) ?> gap-12 mb-12">

            <?php for ($i = 1; $i <= $layout; $i++): ?>
                <?php $columnData = $footerViewModel->getColumnData($i); ?>
                <?php if ($columnData['enabled']): ?>

                    <?php if ($i === 1): ?>
                        <!-- Brand Column -->
                        <div>
                            <?php if (!empty($columnData['show_logo'])): ?>
                                <div class="mb-6"><?= $block->getChildHtml('logo') ?></div>
                            <?php endif; ?>

                            <?php if (!empty($columnData['content'])): ?>
                                <p class="panth-footer-text opacity-90 mb-6 leading-relaxed">
                                    <?= $escaper->escapeHtml($columnData['content']) ?>
                                </p>
                            <?php endif; ?>

                            <?php if (!empty($columnData['show_social'])): ?>
                                <?php $socialLinks = $footerViewModel->getSocialLinks(); ?>
                                <?php if (!empty($socialLinks)): ?>
                                    <div>
                                        <p class="panth-footer-follow-label text-sm font-semibold mb-4">
                                            <?= $escaper->escapeHtml(__('Follow Us')) ?>
                                        </p>
                                        <div class="flex gap-3">
                                            <?php foreach ($socialLinks as $platform => $url): ?>
                                                <a href="<?= $escaper->escapeUrl($url) ?>"
                                                   target="_blank"
                                                   rel="noopener noreferrer"
                                                   class="panth-social-icon w-10 h-10 rounded-lg flex items-center justify-center"
                                                   aria-label="<?= $escaper->escapeHtmlAttr(ucfirst($platform)) ?>">
                                                    <?= /* @noEscape */ $footerViewModel->getSocialIcon($platform) ?>
                                                </a>
                                            <?php endforeach; ?>
                                        </div>
                                    </div>
                                <?php endif; ?>
                            <?php endif; ?>
                        </div>

                    <?php elseif ($i === 4 && !empty($columnData['show_contact_info'])): ?>
                        <!-- Contact Column -->
                        <div>
                            <h3 class="panth-footer-h3 text-lg font-bold mb-6">
                                <?= $escaper->escapeHtml($columnData['title']) ?>
                            </h3>
                            <div class="space-y-4">
                                <?php if (!empty($columnData['phone'])): ?>
                                    <a href="tel:<?= $escaper->escapeHtmlAttr(
                                        preg_replace('/[^0-9+]/', '', $columnData['phone'])
                                    ) ?>"
                                       class="panth-footer-text opacity-85 flex items-center gap-3 transition-colors hover:opacity-100">
                                        <i class="fas fa-phone w-5"></i>
                                        <span><?= $escaper->escapeHtml($columnData['phone']) ?></span>
                                    </a>
                                <?php endif; ?>

                                <?php if (!empty($columnData['email'])): ?>
                                    <a href="mailto:<?= $escaper->escapeHtmlAttr($columnData['email']) ?>"
                                       class="panth-footer-text opacity-85 flex items-center gap-3 transition-colors hover:opacity-100">
                                        <i class="fas fa-envelope w-5"></i>
                                        <span><?= $escaper->escapeHtml($columnData['email']) ?></span>
                                    </a>
                                <?php endif; ?>

                                <?php if (!empty($columnData['address'])): ?>
                                    <div class="panth-footer-text opacity-85 flex items-start gap-3">
                                        <i class="fas fa-map-marker-alt w-5 mt-1"></i>
                                        <span><?= $escaper->escapeHtml($columnData['address'], ['br']) ?></span>
                                    </div>
                                <?php endif; ?>
                            </div>
                        </div>

                    <?php else: ?>
                        <!-- Link Columns -->
                        <div>
                            <h3 class="panth-footer-h3 text-lg font-bold mb-6">
                                <?= $escaper->escapeHtml($columnData['title']) ?>
                            </h3>
                            <?php if (!empty($columnData['links'])): ?>
                                <ul class="space-y-3">
                                    <?php foreach ($columnData['links'] as $link): ?>
                                        <li>
                                            <a href="<?= $escaper->escapeUrl($link['url'] ?? '#') ?>"
                                               class="panth-footer-text opacity-85 transition-colors hover:opacity-100">
                                                <?= $escaper->escapeHtml($link['title'] ?? '') ?>
                                            </a>
                                        </li>
                                    <?php endforeach; ?>
                                </ul>
                            <?php endif; ?>
                        </div>
                    <?php endif; ?>

                <?php endif; ?>
            <?php endfor; ?>

        </div>

        <!-- Footer Bottom -->
        <div class="panth-footer-bottom border-t pt-8">
            <div class="flex flex-col md:flex-row justify-between items-center gap-4 text-sm">
                <div class="panth-footer-copyright">
                    <?= $escaper->escapeHtml($footerViewModel->getCopyrightText(), ['br']) ?>
                </div>

                <?php if ($footerViewModel->showPaymentIcons()): ?>
                    <div class="flex items-center gap-4">
                        <i class="fab fa-cc-visa text-3xl panth-footer-payment-icon"></i>
                        <i class="fab fa-cc-mastercard text-3xl panth-footer-payment-icon"></i>
                        <i class="fab fa-cc-paypal text-3xl panth-footer-payment-icon"></i>
                        <i class="fab fa-cc-amex text-3xl panth-footer-payment-icon"></i>
                    </div>
                <?php endif; ?>

                <?php if ($footerViewModel->showFooterLinks()): ?>
                    <?php $bottomLinks = $footerViewModel->getFooterLinks(); ?>
                    <?php if (!empty($bottomLinks)): ?>
                        <div class="flex gap-4">
                            <?php foreach ($bottomLinks as $link): ?>
                                <a href="<?= $escaper->escapeUrl($link['url'] ?? '#') ?>"
                                   class="panth-footer-bottom-link">
                                    <?= $escaper->escapeHtml($link['title'] ?? '') ?>
                                </a>
                            <?php endforeach; ?>
                        </div>
                    <?php endif; ?>
                <?php endif; ?>
            </div>
        </div>

    </div>
</footer>
