declare(strict_types=1);

use Magento\Framework\Escaper;
use Magento\Framework\View\Element\Template;
use Panth\Footer\ViewModel\FooterData;

/** @var Escaper $escaper */
/** @var Template $block */
/** @var FooterData $footerViewModel */
$footerViewModel = $block->getData('footer_view_model');
if (!$footerViewModel || !$footerViewModel->isNewsletterEnabled()) {
    return;
}

$title = $footerViewModel->getNewsletterTitle() ?: 'Stay in the Loop';
$subtitle = $footerViewModel->getNewsletterSubtitle()
    ?: 'Subscribe to our newsletter for exclusive deals, new arrivals, and special offers.';
$placeholder = $footerViewModel->getNewsletterPlaceholder();
$buttonText = $footerViewModel->getNewsletterButtonText();
$benefits = $footerViewModel->getNewsletterBenefits();
$formKey = $block->getFormKey();
$formAction = $block->getUrl('newsletter/subscriber/new');
?>

<div class="panth-newsletter" style="padding:80px 0;">
    <div style="max-width:1152px;margin:0 auto;padding:0 24px;">
        <div style="text-align:center;margin-bottom:48px;">
            <h2 class="panth-newsletter-title">
                <?= $escaper->escapeHtml($title) ?>
            </h2>
            <p class="panth-newsletter-text" style="max-width:672px;margin:16px auto 0;">
                <?= $escaper->escapeHtml($subtitle) ?>
            </p>
        </div>

        <form action="<?= $escaper->escapeUrl($formAction) ?>"
              method="post"
              id="panth-newsletter-form"
              style="max-width:672px;margin:0 auto;">
            <input type="hidden" name="form_key" value="<?= $escaper->escapeHtmlAttr($formKey) ?>" />
            <div style="display:flex;flex-wrap:wrap;gap:16px;">
                <input type="email"
                       name="email"
                       id="panth-newsletter-email"
                       required
                       placeholder="<?= $escaper->escapeHtmlAttr($placeholder) ?>"
                       class="panth-newsletter-input" />
                <button type="submit"
                        id="panth-newsletter-btn"
                        class="panth-newsletter-button">
                    <span id="panth-nl-text"><?= $escaper->escapeHtml($buttonText) ?></span>
                    <span id="panth-nl-loading" style="display:none;"><?= $escaper->escapeHtml(__('Subscribing...')) ?></span>
                </button>
            </div>

            <div id="panth-newsletter-msg"
                 style="display:none;margin-top:16px;padding:16px;border-radius:8px;text-align:center;font-size:15px;"></div>

            <?php if (!empty($benefits)): ?>
            <div style="margin-top:32px;display:flex;flex-wrap:wrap;justify-content:center;gap:24px;font-size:14px;">
                <?php foreach ($benefits as $benefit): ?>
                <div style="display:flex;align-items:center;gap:8px;">
                    <svg class="panth-newsletter-check" width="20" height="20" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd"
                              d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"/>
                    </svg>
                    <span><?= $escaper->escapeHtml($benefit) ?></span>
                </div>
                <?php endforeach; ?>
            </div>
            <?php endif; ?>
        </form>
    </div>
</div>

<script>
(function() {
    var form = document.getElementById('panth-newsletter-form');
    if (!form) return;
    var btn = document.getElementById('panth-newsletter-btn');
    var textEl = document.getElementById('panth-nl-text');
    var loadEl = document.getElementById('panth-nl-loading');
    var msgEl = document.getElementById('panth-newsletter-msg');
    var emailEl = document.getElementById('panth-newsletter-email');

    form.addEventListener('submit', function(e) {
        e.preventDefault();
        if (!emailEl.value) return;

        textEl.style.display = 'none';
        loadEl.style.display = 'inline';
        btn.disabled = true;
        btn.style.opacity = '0.6';
        msgEl.style.display = 'none';

        var fd = new FormData(form);
        fetch(form.action, {
            method: 'POST',
            body: fd,
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        }).then(function(res) {
            textEl.style.display = 'inline';
            loadEl.style.display = 'none';
            btn.disabled = false;
            btn.style.opacity = '1';

            if (res.ok) {
                msgEl.style.display = 'block';
                msgEl.style.background = '#dcfce7';
                msgEl.style.color = '#166534';
                msgEl.textContent = '<?= $escaper->escapeJs(__('Thank you for subscribing!')) ?>';
                emailEl.value = '';
            } else {
                msgEl.style.display = 'block';
                msgEl.style.background = '#fee2e2';
                msgEl.style.color = '#991b1b';
                msgEl.textContent = '<?= $escaper->escapeJs(__('Something went wrong. Please try again.')) ?>';
            }
        }).catch(function() {
            textEl.style.display = 'inline';
            loadEl.style.display = 'none';
            btn.disabled = false;
            btn.style.opacity = '1';
            msgEl.style.display = 'block';
            msgEl.style.background = '#fee2e2';
            msgEl.style.color = '#991b1b';
            msgEl.textContent = '<?= $escaper->escapeJs(__('Something went wrong. Please try again.')) ?>';
        });
    });
})();
</script>
